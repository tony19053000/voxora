OPENAI_API_KEY=
GROQ_API_KEY=

# Optional overrides
DEFAULT_AI_PROVIDER=auto
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant

# Comma-separated list for local dev and production frontend origins
CORS_ORIGINS=http://localhost:3118,http://127.0.0.1:3118

# Upload / summary tuning
MAX_UPLOAD_MB=25
SUMMARY_CHUNK_CHARS=12000
SUMMARY_CHUNK_OVERLAP=500
